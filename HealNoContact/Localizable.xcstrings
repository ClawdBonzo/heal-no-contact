            "state": "translated",
            "value": "Tu as entamé ton chemin de guérison"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai iniziato il tuo percorso di guarigione"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você começou sua jornada de cura"
          }
        }
