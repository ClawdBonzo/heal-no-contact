    "No contact is not about them. It's about you choosing yourself.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein Kontakt geht nicht um sie. Es geht darum, dass du dich für dich entscheidest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El contacto cero no va sobre ellos. Va sobre que te elijas a ti."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "El no contacto no se trata de ellos. Se trata de que te elijas a ti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le no contact, ce n'est pas pour eux. C'est toi qui te choisis."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il no contact non riguarda loro. Riguarda te che scegli te stesso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O contato zero não é sobre eles. É sobre você escolher a si mesmo."
          }
        }
      }
    },
