    "This will permanently delete all your journal entries, mood data, milestones, and profile. This cannot be undone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle deine Tagebucheinträge, Stimmungsdaten, Meilensteine und dein Profil dauerhaft gelöscht. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará de forma permanente todas tus entradas del diario, datos de ánimo, hitos y perfil. No se puede deshacer."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará permanentemente todas tus entradas del diario, datos de ánimo, hitos y perfil. No se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette action supprimera définitivement toutes vos entrées de journal, vos données d'humeur, vos étapes et votre profil. C'est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa azione eliminerà definitivamente tutte le voci del diario, i dati sull'umore, i traguardi e il profilo. Non potrà essere annullata."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso vai excluir permanentemente todos os seus registros do diário, dados de humor, marcos e perfil. Não há como desfazer."
          }
        }
      }
    },
