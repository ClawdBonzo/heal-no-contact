    "Honesty takes courage. Your streak will reset, but your growth won't.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ehrlichkeit braucht Mut. Deine Serie beginnt neu, dein Wachstum bleibt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ser honesto requiere valor. Tu racha se reiniciará, pero tu crecimiento no."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Ser honesto toma valor. Tu racha se reiniciará, pero tu crecimiento no."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'honnêteté demande du courage. Votre série repart à zéro, mais pas vos progrès."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'onestà richiede coraggio. La tua serie ripartirà, ma la tua crescita no."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ser honesto exige coragem. Sua sequência será zerada, mas seu crescimento não."
          }
        }
      }
    },
