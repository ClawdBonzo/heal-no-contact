    "Your current streak will be reset to 0. Your best streak and history will be preserved.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine aktuelle Serie wird auf 0 zurückgesetzt. Deine beste Serie und dein Verlauf bleiben erhalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu racha actual se pondrá a 0. Se conservarán tu mejor racha y tu historial."
          }
