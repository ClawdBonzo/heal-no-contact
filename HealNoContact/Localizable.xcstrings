    "Writing helps process emotions and track your healing. Start with whatever's on your mind.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schreiben hilft, Gefühle zu verarbeiten und deine Heilung zu verfolgen. Beginne mit allem, was dir gerade durch den Kopf geht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribir ayuda a procesar las emociones y a seguir tu sanación. Empieza por lo que tengas en mente."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
