    "You are allowed to be both a masterpiece and a work in progress.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du darfst zugleich ein Meisterwerk und ein Werk im Werden sein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes ser a la vez una obra maestra y un trabajo en progreso."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes ser una obra maestra y un trabajo en proceso al mismo tiempo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu as le droit d'être à la fois un chef-d'œuvre et une œuvre en devenir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai il diritto di essere allo stesso tempo un capolavoro e un'opera in divenire."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode ser, ao mesmo tempo, uma obra-prima e uma obra em construção."
          }
        }
      }
    },
    "You can't start the next chapter if you keep re-reading the last one.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kannst das nächste Kapitel nicht beginnen, wenn du immer wieder das letzte liest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No puedes empezar el siguiente capítulo si sigues releyendo el anterior."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "No puedes empezar el siguiente capítulo si sigues releyendo el anterior."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu ne peux pas commencer le prochain chapitre si tu relis sans cesse le précédent."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non puoi iniziare il prossimo capitolo se continui a rileggere l'ultimo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você não consegue começar o próximo capítulo se continuar relendo o anterior."
          }
        }
      }
    },
    "You did it!": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast es geschafft!"
          }
        },
        "es": {
