        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez réussi !"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce l'hai fatta!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você conseguiu!"
          }
        }
      }
    },
    "You don't need closure from them. You need peace from within.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du brauchst keinen Abschluss von ihnen. Du brauchst Frieden in dir selbst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No necesitas que ellos cierren el ciclo. Necesitas paz dentro de ti."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "No necesitas que ellos te den un cierre. Necesitas paz dentro de ti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu n'as pas besoin qu'ils tournent la page pour toi. Tu as besoin de paix au-dedans."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non hai bisogno di chiusura da parte loro. Hai bisogno di pace dentro di te."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você não precisa que eles fechem esse ciclo. Você precisa de paz por dentro."
          }
        }
      }
    },
    "You resisted the urge.\nThat takes real strength.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast dem Drang widerstanden.\nDas erfordert echte Stärke."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has resistido el impulso.\nEso requiere verdadera fuerza."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Resististe el impulso.\nEso requiere verdadera fortaleza."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez résisté à l'envie.\nCela demande une vraie force."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai resistito all'impulso.\nCi vuole vera forza."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você resistiu à vontade.\nIsso exige uma força de verdade."
          }
        }
      }
    },
    "You started your healing journey": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast deine Heilungsreise begonnen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empezaste tu camino de sanación"
