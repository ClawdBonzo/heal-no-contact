    "Most urges peak at 10-20 minutes then fade. You're doing great.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die meisten Impulse erreichen nach 10–20 Minuten ihren Höhepunkt und verschwinden dann. Du machst das großartig."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La mayoría de los impulsos llegan al máximo a los 10-20 minutos y luego se desvanecen. Lo estás haciendo genial."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "La mayoría de los impulsos llegan a su punto máximo en 10-20 minutos y luego se desvanecen. Lo estás haciendo muy bien."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La plupart des envies culminent entre 10 et 20 minutes puis s'apaisent. Vous vous en sortez très bien."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La maggior parte degli impulsi raggiunge il picco in 10-20 minuti, poi svanisce. Stai andando alla grande."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A maioria das vontades atinge o pico em 10 a 20 minutos e depois passa. Você está indo muito bem."
          }
        }
      }
    },
