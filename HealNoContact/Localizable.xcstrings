    "Growth is painful. Change is painful. But nothing is as painful as staying stuck.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wachstum tut weh. Veränderung tut weh. Doch nichts tut so weh, wie stehen zu bleiben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crecer duele. Cambiar duele. Pero nada duele tanto como quedarte atascado."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Crecer duele. Cambiar duele. Pero nada duele tanto como quedarse estancado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grandir fait mal. Changer fait mal. Mais rien ne fait plus mal que de rester figé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Crescere fa male. Cambiare fa male. Ma niente fa più male del restare bloccati."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Crescer dói. Mudar dói. Mas nada dói tanto quanto continuar preso no mesmo lugar."
          }
        }
      }
    },
